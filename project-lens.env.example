# project-lens configuration
# Copy to ~/.claude/project-lens.env and fill in your values.
# Changes take effect immediately — no restart needed.
#
# cp project-lens.env.example ~/.claude/project-lens.env

# Your OpenRouter API key — get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Model to use for scanning and searching.
# Free options (check current availability at openrouter.ai/models?q=free):
#   qwen/qwen-2.5-72b-instruct:free
#   google/gemma-3-27b-it:free
#   mistralai/mistral-7b-instruct:free
# Paid (cheap, high quality):
#   deepseek/deepseek-chat
#   anthropic/claude-haiku-4-5
OPENROUTER_MODEL=qwen/qwen-2.5-72b-instruct:free
